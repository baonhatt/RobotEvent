GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional: external API base URL for production deployments (e.g. Cloudflare Worker).
# Leave empty in local dev to use Vite proxy + /api path.
VITE_API_BASE_URL=""

# Contact endpoint path on your API host.
# Use "/api/contact" for local proxy, or "/contact" if your Worker exposes that route.
VITE_CONTACT_API_PATH="/contact"

# Resend API key used by the Express contact endpoint.
RESEND_API_KEY="YOUR_RESEND_API_KEY"

# Email inbox where contact form submissions are sent.
CONTACT_TO_EMAIL="baonhat20@gmail.com"

# Verified sender in Resend (must be from your verified domain or onboarding sender).
CONTACT_FROM_EMAIL="RobotEvent <noreply@yourdomain.com>"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
